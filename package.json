{
  "name": "arish-shah.github.io",
  "type": "module",
  "scripts": {
    "prebuild": "rm -rf docs",
    "build-html": "tsx ./src/index.ts",
    "build-css": "tailwindcss -i ./src/input.css -o ./docs/output.css --minify",
    "build": "npm run build-html && npm run build-css",
    "dev-html": "nodemon",
    "dev-css": "tailwindcss -i ./src/input.css -o ./docs/output.css --watch",
    "dev": "concurrently \"npm:dev-html\" \"npm:dev-css\" \"npm:preview\"",
    "prepare": "husky",
    "prettier": "prettier . --write",
    "preview": "live-server docs"
  },
  "devDependencies": {
    "@types/fs-extra": "latest",
    "@types/html-minifier-terser": "latest",
    "@types/node": "latest",
    "cheerio": "latest",
    "concurrently": "latest",
    "fs-extra": "latest",
    "gray-matter": "latest",
    "html-minifier-terser": "latest",
    "husky": "latest",
    "live-server": "latest",
    "nodemon": "latest",
    "prettier": "latest",
    "prettier-plugin-tailwindcss": "latest",
    "remark-html": "latest",
    "remark-parse": "latest",
    "tailwindcss": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "unified": "latest"
  }
}
